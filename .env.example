# Copy to .env and adjust. The defaults below run the full pipeline in sandbox
# mode with NO external accounts required (LLM + Knowledge use the local
# services from docker-compose). Never commit a real .env.

# --- Core ---
APP_ENV=local                      # local | ci | production
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
# Comma-separated allowlist. Do NOT use "*" in production.
CORS_ORIGINS=http://localhost:3000

# --- Security / JWT ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production-use-a-48-byte-random-secret
JWT_ISSUER=enterprise-ai-ops-agent
JWT_TTL_SECONDS=3600
# Bootstrap service account used by POST /v1/auth/token (password is bcrypt-verified).
SERVICE_ACCOUNT_ID=ops-service
SERVICE_ACCOUNT_PASSWORD=local-dev-password

# --- Rate limiting (per token subject, falls back to client IP) ---
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# --- PostgreSQL ---
POSTGRES_DSN=postgresql+asyncpg://ops:ops@localhost:5432/ops

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
JOB_QUEUE_KEY=ops:jobs
MAX_ATTEMPTS=3

# --- LLM (OpenAI-compatible) ---
# Ships as sandbox so the stack runs with zero setup. Set to `real` to use a
# local Ollama (or any OpenAI-compatible endpoint) via LLM_BASE_URL below.
LLM_MODE=sandbox                   # real | sandbox
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama                 # Ollama ignores this; real OpenAI needs a key
LLM_CHAT_MODEL=llama3.1
LLM_EMBED_MODEL=nomic-embed-text
LLM_TIMEOUT_SECONDS=60

# --- Knowledge / Qdrant ---
# Keep in lockstep with LLM_MODE: real retrieval embeds via the real LLM, so
# QDRANT_VECTOR_SIZE must match the embedding model's output dimension.
KNOWLEDGE_MODE=sandbox             # real | sandbox
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=company_knowledge
QDRANT_VECTOR_SIZE=768             # must match LLM_EMBED_MODEL output dim

# --- Slack (designated real end-to-end integration) ---
SLACK_MODE=sandbox                 # real | sandbox; set real + webhook to enable
SLACK_WEBHOOK_URL=
SLACK_DEFAULT_CHANNEL=#ops-alerts

# --- Jira ---
JIRA_MODE=sandbox                  # real | sandbox
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=OPS

# --- Email (SMTP) ---
EMAIL_MODE=sandbox                 # real | sandbox
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=ops@example.com

# --- Error tracking (optional; no-op if unset) ---
SENTRY_DSN=
